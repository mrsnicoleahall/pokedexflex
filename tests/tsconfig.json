{
	"extends": "../tsconfig.worker.json",
	"compilerOptions": {
		"tsBuildInfoFile": "../node_modules/.tmp/tsconfig.tests.tsbuildinfo",
		"types": ["vite/client", "../worker-configuration.d.ts", "@cloudflare/vitest-pool-workers/types"]
	},
	"include": ["**/*.ts", "../src/worker/**/*.ts"],
	// React-app unit tests are DOM-libbed and type-checked by tsconfig.react.json;
	// keeping them out of this Workers-only project avoids re-checking DOM-typed
	// src/react-app source (e.g. api.ts) against the Workers RequestInit.
	"exclude": ["react-app"]
}
